generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum MembershipRole {
  /// MVP keeps SUPER_ADMIN in MembershipRole so platform operators use the same role pipeline.
  SUPER_ADMIN
  ORG_ADMIN
  INSTRUCTOR
  STUDENT
}

enum UserStatus {
  ACTIVE
  INVITED
  SUSPENDED
  ARCHIVED
}

enum OrganizationStatus {
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum AttendanceSessionStatus {
  DRAFT
  SCHEDULED
  ACTIVE
  CLOSED
  CANCELLED
}

enum AttendanceSessionGeofenceSource {
  DEVICE
  ROOM
  MANUAL
  NONE
}

enum AttendanceRecordStatus {
  PRESENT
  LATE
  ABSENT
  EXCUSED
  REJECTED
  MANUAL
}

enum AttendanceSource {
  QR_SCAN
  MANUAL_ENTRY
  SYSTEM_GENERATED
}

enum EnrollmentStatus {
  ACTIVE
  INACTIVE
  COMPLETED
  WITHDRAWN
  SUSPENDED
}

enum AttendanceVerificationLevel {
  INITIAL_ONLY
  MID_SESSION_VERIFIED
  CONTINUOUSLY_VERIFIED
  SUSPICIOUS
  MANUAL_REVIEW
}

enum PresenceCheckType {
  INITIAL_CHECK_IN
  PERIODIC_LOCATION
  MID_SESSION_QR
  MANUAL_CHECK
}

enum PresenceCheckStatus {
  INSIDE_GEOFENCE
  OUTSIDE_GEOFENCE
  LOW_ACCURACY
  LOCATION_UNAVAILABLE
  QR_NOT_CONFIRMED
  SUSPICIOUS
  VERIFIED
}

enum AttendanceAlertType {
  LEFT_GEOFENCE
  OUTSIDE_GEOFENCE
  LOW_ACCURACY_LOCATION
  DUPLICATE_CHECK_IN_ATTEMPT
  EXPIRED_TOKEN_ATTEMPT
  REVOKED_TOKEN_ATTEMPT
  STUDENT_NOT_ENROLLED
  SESSION_CLOSED_ATTEMPT
  INVALID_TOKEN_ATTEMPT
  MULTI_DEVICE_ATTEMPT
  SUSPICIOUS_TOKEN_REUSE
  TOKEN_REPLACED_BY_NEW_QR
  DEVICE_REGISTERED
  MISSED_MID_SESSION_CHECK
  LOCATION_PERMISSION_LOST
  SUSPICIOUS_RECHECK
  DUPLICATE_ATTEMPT
  MANUAL_REVIEW
}

enum AttendanceAlertSeverity {
  LOW
  MEDIUM
  HIGH
}

model Organization {
  id        String             @id @default(cuid())
  name      String
  slug      String             @unique
  status    OrganizationStatus @default(ACTIVE)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  memberships         Membership[]
  rooms               Room[]
  courses             Course[]
  sections            Section[]
  enrollments         Enrollment[]
  attendanceSessions  AttendanceSession[]
  qrTokens            QRToken[]
  attendanceRecords   AttendanceRecord[]
  presenceChecks      PresenceCheck[]
  attendanceAlerts    AttendanceAlert[]
  auditLogs           AuditLog[]
  deviceSessions      DeviceSession[]
  attendanceDevices   AttendanceDevice[]
  sectionAssignments  InstructorSectionAssignment[]
  passwordResetTokens PasswordResetToken[]

  @@index([status])
  @@map("organizations")
}

model User {
  id                 String     @id @default(cuid())
  email              String     @unique
  name               String?
  passwordHash       String?
  mustChangePassword Boolean    @default(false)
  status             UserStatus @default(ACTIVE)
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  memberships         Membership[]
  passwordResetTokens PasswordResetToken[]
  auditLogs           AuditLog[]           @relation("AuditLogActor")
  deviceSessions      DeviceSession[]
  attendanceRecords   AttendanceRecord[]   @relation("AttendanceRecordStudentUser")
  presenceChecks      PresenceCheck[]      @relation("PresenceCheckStudentUser")
  attendanceAlerts    AttendanceAlert[]    @relation("AttendanceAlertStudentUser")
  attendanceDevices   AttendanceDevice[]   @relation("AttendanceDeviceUser")

  @@index([status])
  @@map("users")
}

model Membership {
  id             String         @id @default(cuid())
  organizationId String
  userId         String
  role           MembershipRole
  studentNo      String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: NoAction)

  instructedSections        Section[]                     @relation("SectionInstructorMembership")
  enrollments               Enrollment[]                  @relation("EnrollmentStudentMembership")
  createdAttendanceSessions AttendanceSession[]           @relation("AttendanceSessionCreatorMembership")
  createdQRTokens           QRToken[]                     @relation("QRTokenCreatorMembership")
  attendanceRecords         AttendanceRecord[]            @relation("AttendanceRecordStudentMembership")
  presenceChecks            PresenceCheck[]               @relation("PresenceCheckStudentMembership")
  attendanceAlerts          AttendanceAlert[]             @relation("AttendanceAlertStudentMembership")
  resolvedAttendanceAlerts  AttendanceAlert[]             @relation("AttendanceAlertResolverMembership")
  sectionAssignments        InstructorSectionAssignment[] @relation("InstructorSectionAssignmentMembership")

  @@unique([organizationId, userId])
  @@unique([id, organizationId])
  @@unique([id, organizationId, userId])
  @@index([organizationId, role])
  @@index([organizationId, studentNo])
  @@index([userId])
  @@map("memberships")
}

model Room {
  id                  String   @id @default(cuid())
  organizationId      String
  name                String
  code                String?
  description         String?
  address             String?
  latitude            Decimal? @db.Decimal(9, 6)
  longitude           Decimal? @db.Decimal(9, 6)
  allowedRadiusMeters Int?
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  organization       Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  attendanceSessions AttendanceSession[]

  @@unique([organizationId, code])
  @@unique([id, organizationId])
  @@index([organizationId, name])
  @@map("rooms")
}

model Course {
  id             String   @id @default(cuid())
  organizationId String
  code           String
  title          String
  description    String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sections     Section[]

  @@unique([organizationId, code])
  @@unique([id, organizationId])
  @@index([organizationId, isActive])
  @@map("courses")
}

model Section {
  id                     String    @id @default(cuid())
  organizationId         String
  courseId               String
  instructorMembershipId String?
  name                   String
  code                   String?
  startsAt               DateTime?
  endsAt                 DateTime?
  isActive               Boolean   @default(true)
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  organization         Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  course               Course       @relation(fields: [courseId, organizationId], references: [id, organizationId], onDelete: NoAction)
  instructorMembership Membership?  @relation("SectionInstructorMembership", fields: [instructorMembershipId, organizationId], references: [id, organizationId], onDelete: NoAction)

  enrollments           Enrollment[]
  attendanceSessions    AttendanceSession[]
  instructorAssignments InstructorSectionAssignment[] @relation("InstructorSectionAssignmentSection")

  @@unique([organizationId, code])
  @@unique([id, organizationId])
  @@index([organizationId, courseId])
  @@index([organizationId, instructorMembershipId])
  @@index([organizationId, isActive])
  @@map("sections")
}

model InstructorSectionAssignment {
  id                     String   @id @default(cuid())
  organizationId         String
  instructorMembershipId String
  sectionId              String
  isActive               Boolean  @default(true)
  assignedAt             DateTime @default(now())
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  organization         Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  instructorMembership Membership   @relation("InstructorSectionAssignmentMembership", fields: [instructorMembershipId, organizationId], references: [id, organizationId], onDelete: NoAction)
  section              Section      @relation("InstructorSectionAssignmentSection", fields: [sectionId, organizationId], references: [id, organizationId], onDelete: NoAction)

  @@unique([organizationId, instructorMembershipId, sectionId])
  @@unique([id, organizationId])
  @@index([organizationId, instructorMembershipId, isActive])
  @@index([organizationId, sectionId, isActive])
  @@map("instructor_section_assignments")
}

model Enrollment {
  id                  String           @id @default(cuid())
  organizationId      String
  sectionId           String
  studentMembershipId String
  status              EnrollmentStatus @default(ACTIVE)
  enrolledAt          DateTime         @default(now())
  endedAt             DateTime?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  section           Section      @relation(fields: [sectionId, organizationId], references: [id, organizationId], onDelete: NoAction)
  studentMembership Membership   @relation("EnrollmentStudentMembership", fields: [studentMembershipId, organizationId], references: [id, organizationId], onDelete: NoAction)

  attendanceRecords AttendanceRecord[]

  @@unique([organizationId, sectionId, studentMembershipId])
  @@unique([id, organizationId])
  @@index([organizationId, status])
  @@index([organizationId, studentMembershipId])
  @@map("enrollments")
}

model AttendanceSession {
  id                     String                          @id @default(cuid())
  organizationId         String
  sectionId              String
  roomId                 String?
  createdByMembershipId  String?
  title                  String
  description            String?
  startTime              DateTime
  endTime                DateTime
  status                 AttendanceSessionStatus         @default(SCHEDULED)
  lateThresholdMinutes   Int                             @default(0)
  geofenceLatitude       Decimal?                        @db.Decimal(9, 6)
  geofenceLongitude      Decimal?                        @db.Decimal(9, 6)
  geofenceAccuracyMeters Decimal?                        @db.Decimal(10, 2)
  geofenceRadiusMeters   Int?
  geofenceCapturedAt     DateTime?
  geofenceSource         AttendanceSessionGeofenceSource @default(NONE)
  createdAt              DateTime                        @default(now())
  updatedAt              DateTime                        @updatedAt

  organization        Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  section             Section      @relation(fields: [sectionId, organizationId], references: [id, organizationId], onDelete: NoAction)
  room                Room?        @relation(fields: [roomId, organizationId], references: [id, organizationId], onDelete: NoAction)
  createdByMembership Membership?  @relation("AttendanceSessionCreatorMembership", fields: [createdByMembershipId, organizationId], references: [id, organizationId], onDelete: NoAction)

  qrTokens          QRToken[]
  attendanceRecords AttendanceRecord[]
  presenceChecks    PresenceCheck[]
  attendanceAlerts  AttendanceAlert[]

  @@unique([id, organizationId])
  @@index([organizationId, status])
  @@index([organizationId, sectionId, startTime])
  @@index([organizationId, roomId])
  @@index([organizationId, createdByMembershipId])
  @@index([organizationId, geofenceSource])
  @@map("attendance_sessions")
}

model QRToken {
  id                    String    @id @default(cuid())
  organizationId        String
  attendanceSessionId   String
  createdByMembershipId String?
  tokenHash             String    @unique
  expiresAt             DateTime
  revokedAt             DateTime?
  createdAt             DateTime  @default(now())

  organization        Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  attendanceSession   AttendanceSession @relation(fields: [attendanceSessionId, organizationId], references: [id, organizationId], onDelete: Cascade)
  createdByMembership Membership?       @relation("QRTokenCreatorMembership", fields: [createdByMembershipId, organizationId], references: [id, organizationId], onDelete: NoAction)

  @@index([organizationId, attendanceSessionId, revokedAt, expiresAt])
  @@index([organizationId, expiresAt])
  @@map("qr_tokens")
}

model AttendanceRecord {
  id                     String                      @id @default(cuid())
  organizationId         String
  attendanceSessionId    String
  studentMembershipId    String
  studentUserId          String
  enrollmentId           String?
  status                 AttendanceRecordStatus
  source                 AttendanceSource
  verificationLevel      AttendanceVerificationLevel @default(INITIAL_ONLY)
  lastVerifiedAt         DateTime?
  suspiciousFlag         Boolean                     @default(false)
  checkedInAt            DateTime?
  locationLatitude       Decimal?                    @db.Decimal(9, 6)
  locationLongitude      Decimal?                    @db.Decimal(9, 6)
  locationAccuracyMeters Int?
  distanceMeters         Decimal?                    @db.Decimal(10, 2)
  rejectionReason        String?
  deviceIdHash           String?
  deviceUserAgent        String?
  ipAddress              String?
  createdAt              DateTime                    @default(now())
  updatedAt              DateTime                    @updatedAt

  organization      Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  attendanceSession AttendanceSession @relation(fields: [attendanceSessionId, organizationId], references: [id, organizationId], onDelete: Cascade)
  studentMembership Membership        @relation("AttendanceRecordStudentMembership", fields: [studentMembershipId, organizationId, studentUserId], references: [id, organizationId, userId], onDelete: NoAction)
  studentUser       User              @relation("AttendanceRecordStudentUser", fields: [studentUserId], references: [id], onDelete: NoAction)
  enrollment        Enrollment?       @relation(fields: [enrollmentId, organizationId], references: [id, organizationId], onDelete: NoAction)
  presenceChecks    PresenceCheck[]
  attendanceAlerts  AttendanceAlert[]

  @@unique([organizationId, attendanceSessionId, studentMembershipId])
  @@unique([id, organizationId])
  @@index([organizationId, status])
  @@index([organizationId, verificationLevel])
  @@index([organizationId, suspiciousFlag])
  @@index([attendanceSessionId, status])
  @@index([organizationId, studentUserId, checkedInAt])
  @@index([organizationId, source])
  @@map("attendance_records")
}

model PresenceCheck {
  id                       String              @id @default(cuid())
  organizationId           String
  attendanceSessionId      String
  attendanceRecordId       String?
  studentUserId            String
  studentMembershipId      String
  checkType                PresenceCheckType
  status                   PresenceCheckStatus
  latitude                 Decimal?            @db.Decimal(9, 6)
  longitude                Decimal?            @db.Decimal(9, 6)
  accuracyMeters           Int?
  distanceToGeofenceMeters Decimal?            @db.Decimal(10, 2)
  checkedAt                DateTime            @default(now())
  metadata                 Json?
  createdAt                DateTime            @default(now())

  organization      Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  attendanceSession AttendanceSession @relation(fields: [attendanceSessionId, organizationId], references: [id, organizationId], onDelete: Cascade)
  attendanceRecord  AttendanceRecord? @relation(fields: [attendanceRecordId, organizationId], references: [id, organizationId], onDelete: NoAction)
  studentUser       User              @relation("PresenceCheckStudentUser", fields: [studentUserId], references: [id], onDelete: NoAction)
  studentMembership Membership        @relation("PresenceCheckStudentMembership", fields: [studentMembershipId, organizationId], references: [id, organizationId], onDelete: NoAction)

  @@index([organizationId, attendanceSessionId])
  @@index([organizationId, studentUserId])
  @@index([organizationId, checkType])
  @@index([organizationId, status])
  @@index([organizationId, checkedAt])
  @@map("presence_checks")
}

model AttendanceAlert {
  id                     String                  @id @default(cuid())
  organizationId         String
  attendanceSessionId    String
  attendanceRecordId     String?
  studentUserId          String?
  studentMembershipId    String?
  alertType              AttendanceAlertType
  severity               AttendanceAlertSeverity
  message                String
  isResolved             Boolean                 @default(false)
  resolvedByMembershipId String?
  resolvedAt             DateTime?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt

  organization         Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  attendanceSession    AttendanceSession @relation(fields: [attendanceSessionId, organizationId], references: [id, organizationId], onDelete: Cascade)
  attendanceRecord     AttendanceRecord? @relation(fields: [attendanceRecordId, organizationId], references: [id, organizationId], onDelete: NoAction)
  studentUser          User?             @relation("AttendanceAlertStudentUser", fields: [studentUserId], references: [id], onDelete: NoAction)
  studentMembership    Membership?       @relation("AttendanceAlertStudentMembership", fields: [studentMembershipId, organizationId], references: [id, organizationId], onDelete: NoAction)
  resolvedByMembership Membership?       @relation("AttendanceAlertResolverMembership", fields: [resolvedByMembershipId, organizationId], references: [id, organizationId], onDelete: NoAction)

  @@index([organizationId, attendanceSessionId])
  @@index([organizationId, studentUserId])
  @@index([organizationId, alertType])
  @@index([organizationId, isResolved])
  @@index([organizationId, severity, isResolved])
  @@index([organizationId, createdAt])
  @@map("attendance_alerts")
}

model AuditLog {
  id             String   @id @default(cuid())
  organizationId String
  actorUserId    String?
  action         String
  targetType     String
  targetId       String?
  metadata       Json?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  actorUser    User?        @relation("AuditLogActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([organizationId, targetType, targetId])
  @@index([actorUserId, createdAt])
  @@map("audit_logs")
}

model PasswordResetToken {
  id             String    @id @default(cuid())
  organizationId String
  userId         String
  tokenHash      String    @unique
  expiresAt      DateTime
  usedAt         DateTime?
  revokedAt      DateTime?
  requestedAt    DateTime  @default(now())
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId, userId, createdAt])
  @@index([tokenHash])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model DeviceSession {
  id               String    @id @default(cuid())
  organizationId   String
  userId           String
  sessionTokenHash String    @unique
  userAgent        String?
  ipAddress        String?
  lastSeenAt       DateTime  @default(now())
  expiresAt        DateTime
  revokedAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: NoAction)

  @@index([organizationId, userId])
  @@index([userId, expiresAt])
  @@index([organizationId, expiresAt])
  @@index([organizationId, lastSeenAt])
  @@map("device_sessions")
}

model AttendanceDevice {
  id               String   @id @default(cuid())
  organizationId   String
  userId           String
  fingerprintHash  String
  userAgentSummary String?
  firstSeenAt      DateTime @default(now())
  lastSeenAt       DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation("AttendanceDeviceUser", fields: [userId], references: [id], onDelete: NoAction)

  @@unique([organizationId, userId, fingerprintHash])
  @@index([organizationId, userId, lastSeenAt])
  @@index([organizationId, fingerprintHash])
  @@map("attendance_devices")
}
